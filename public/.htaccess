# ─── HTTPS + www Redirect ─────────────────────────────────────
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

RewriteCond %{HTTP_HOST} ^meister-signage\.ch$ [NC]
RewriteRule ^ https://www.meister-signage.ch%{REQUEST_URI} [L,R=301]

# ─── Legacy URL Redirects (301) ───────────────────────────────
# Alte URLs aus der WordPress-Zeit → neue strukturierte URLs.
# Schlank über Apache/LiteSpeed statt thin-content Page-Stubs.
RedirectMatch 301 ^/mieten/?$                  /digital-signage-mieten/
RedirectMatch 301 ^/hotellerie/?$              /branchen/hotellerie/
RedirectMatch 301 ^/gastronomie/?$             /branchen/gastronomie/
RedirectMatch 301 ^/retail/?$                  /branchen/retail/
RedirectMatch 301 ^/unternehmen/?$             /branchen/unternehmen/
RedirectMatch 301 ^/events/?$                  /branchen/events/
RedirectMatch 301 ^/digitales-menueboard/?$    /loesungen/digitale-menueboards/
RedirectMatch 301 ^/digital-signage-hotel-empfang/?$ /branchen/hotellerie/
RedirectMatch 301 ^/news/digital-signage-gastronomie-2025/?$ /news/digital-signage-gastronomie-2026/
# Verwaiste WordPress-URLs mit Rankings/Impressionen (GSC) → passende Live-Seite
RedirectMatch 301 ^/digital-signage-retail/?$        /branchen/retail/
RedirectMatch 301 ^/digital-signage-gastronomie/?$   /branchen/gastronomie/
RedirectMatch 301 ^/datenschutz-meister-signage/?$   /datenschutz/
RedirectMatch 301 ^/designservice-fuer-digital-signage/?$ /
RedirectMatch 301 ^/lift-and-play/?$                 /
# Hinweis: /digital-signage-wie-red-bull/ wird als echte Seite neu aufgebaut (kein Redirect).

# ─── Security Headers ──────────────────────────────────────────
# Meister Signage — Novatrend / LiteSpeed
# Deployed to public/ and copied to out/ during build.

# Prevent clickjacking
Header set X-Frame-Options "SAMEORIGIN"

# Prevent MIME-type sniffing
Header set X-Content-Type-Options "nosniff"

# Referrer policy — send origin only to external sites
Header set Referrer-Policy "strict-origin-when-cross-origin"

# Permissions policy — disable unnecessary browser APIs
Header set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"

# XSS protection (legacy browsers)
Header set X-XSS-Protection "1; mode=block"

# ─── Charset im HTTP-Header (UTF-8) ───────────────────────────
# Ergänzt "; charset=utf-8" am Content-Type für Text-Antworten
# (behebt Seobility-Warnung "Es fehlen Zeichensatzangaben im HTTP Header").
AddDefaultCharset utf-8
AddCharset utf-8 .html .css .js .xml .svg .json .txt

Header set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

# Content Security Policy
Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://identity.netlify.com https://unpkg.com https://www.googletagmanager.com https://www.google-analytics.com https://www.clarity.ms; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://api.github.com https://*.workers.dev https://formspree.io https://www.google-analytics.com https://analytics.google.com https://*.clarity.ms; frame-src 'self' https://identity.netlify.com; base-uri 'self'; form-action 'self' https://formspree.io;"

# ─── Test subdomain: prevent indexing ────────────────────────
SetEnvIf Host "^test\." TEST_ENV
Header set X-Robots-Tag "noindex, nofollow" env=TEST_ENV

# ─── Caching ──────────────────────────────────────────────────

# Static assets — 1 year cache (hashed filenames)
<FilesMatch "\.(js|css|woff2|woff|ttf|ico)$">
  Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

# Images — 30 days
<FilesMatch "\.(png|jpg|jpeg|webp|avif|svg|gif)$">
  Header set Cache-Control "public, max-age=2592000"
</FilesMatch>

# HTML — no cache (always fresh)
<FilesMatch "\.(html)$">
  Header set Cache-Control "public, max-age=0, must-revalidate"
</FilesMatch>

# ─── Compression ──────────────────────────────────────────────

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# ─── Error documents ─────────────────────────────────────────

ErrorDocument 404 /404.html
