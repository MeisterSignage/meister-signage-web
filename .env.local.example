# Formspree Form ID
# 1. Konto erstellen: https://formspree.io
# 2. Neues Formular anlegen → E-Mail: info@meister-signage.ch
# 3. Form ID aus der URL kopieren (z.B. xpzgkrvl)
# 4. Hier eintragen und Datei als .env.local speichern
NEXT_PUBLIC_FORMSPREE_ID=xxxxxxxx

# SEO indexability switch (Build-Zeit)
# - "true"  oder ungesetzt → Suchmaschinen erlaubt   (www.meister-signage.ch)
# - "false"                → noindex/nofollow + Disallow: / + leere Sitemap
#                            (test.meister-signage.ch / Staging / Pre-Launch)
#
# Beispiel Staging-Build:
#   NEXT_PUBLIC_SITE_INDEXABLE=false npm run build
NEXT_PUBLIC_SITE_INDEXABLE=true
